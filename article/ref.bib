@article{Bohman,
  title = {Six Lonely Runners},
  volume = {8},
  url = {https://www.combinatorics.org/ojs/index.php/eljc/article/view/v8i2r3},
  DOI = {10.37236/1602},
  abstractNote = {&lt;p&gt;For $x$ real, let $ \{x\}$ be the fractional part of
                  $x$ (i.e. $ \{x\} = x - \lfloor x \rfloor $). In this paper we
                  prove the $k=5$ case of the following conjecture (the lonely
                  runner conjecture): for any $k$ positive reals $ v_1, \dots ,
                  v_k $ there exists a real number $t$ such that $ 1/(k+1) \le \{
                  v_it \} \le k/(k+1) $ for $ i= 1, \dots, k$.&lt;/p&#38;gt;},
  number = {2},
  journal = {The Electronic Journal of Combinatorics},
  author = {Bohman, Tom and Holzman, Ron and Kleitman, Dan},
  year = {2001},
  month = {Feb.},
  pages = {R3},
}


